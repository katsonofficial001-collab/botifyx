# ─── Server ──────────────────────────────────────────────
PORT=3000
SESSION_SECRET=change-me-to-a-long-random-string

# ─── WhatsApp bot ────────────────────────────────────────
# Optional. If set, this number is pre-filled in the /pair portal form.
# Including country code, no plus sign. Example: 2349075928878
BOT_PHONE_NUMBER=2349075928878

# Owner number that receives forwarded view-once / status media.
# Same format as above. Defaults to 2349075928878 if not set.
OWNER_NUMBER=2349075928878

# Default command prefix
PREFIX=*

# Owner admin panel password (optional override).
# A built-in default password is used if this is left unset.
# OWNER_PASSWORD=

# ─── OpenAI ──────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ─── Logging ─────────────────────────────────────────────
LOG_LEVEL=info
NODE_ENV=production
